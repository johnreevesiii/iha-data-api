# IHA Data API — Environment Variables
# Copy to .env and fill in values

# Auth — MUST match marketplace JWT_SECRET
JWT_SECRET=your-shared-jwt-secret

# CORS — marketplace URL(s), comma-separated
ALLOWED_ORIGINS=http://localhost:5173,https://iha-consultant-marketplace.vercel.app

# Optional: Census Bureau API key (higher rate limits)
CENSUS_API_KEY=

# Optional: Socrata (data.cdc.gov, data.cms.gov) app token
SOCRATA_APP_TOKEN=

# Debug mode (set to true for verbose logging)
DEBUG=false
